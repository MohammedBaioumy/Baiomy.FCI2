@model DepartmentViewModel

<div class="form-group ">
    <label asp-for="Code" class="mt-2 mb-1"></label>
    <input asp-for="Code" type="text" class="form-control">
    <span asp-validation-for="Code" class="text-danger"></span>
</div>
<div class="form-group ">
    <label asp-for="Name" class="mt-2 mb-1"></label>
    <input asp-for="Name" type="text" class="form-control">

    <span asp-validation-for="Name" class="text-danger"></span>

</div>
<div class="form-group  ">

    <label asp-for="Description" class="mt-2 mb-1"></label>
    <textarea asp-for="Description" class="form-control" placeholder="Description"></textarea>
    <span asp-validation-for="Description" class="text-danger"></span>

</div>
<div class="form-group  mb-3">
    <label asp-for="CreationDate" class="mt-2  mb-1"></label>
    <input asp-for="CreationDate" type="date" class="form-control">
    <span asp-validation-for="CreationDate" class="text-danger"></span>

</div>
           
