@model List<UserInRoleViewModel>
@{
    ViewData["Title"] = "UserInRole";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var role = ViewData["RoleId"];
}

<h1>Add or remove users</h1>
<form asp-action="UserInRole" asp-route-RoleId="@role">

    @for (int i = 0; i < Model.Count; i++)
    {
        <div class="row">
           <div class=" col-lg-4 form-group m-1 fs-5">
                <input asp-for="@Model[i].IsInRole">
             <label asp-for="@Model[i].IsInRole" class="mt-1 mb-1">@Model[i].UserName</label>
             
             <input type="hidden" asp-for="@Model[i].UserId" />
             <input type="hidden" asp-for="@Model[i].UserName" />
           </div>
        </div>



    }
    <div class="row">
    <div class="  p-2  w-50 ">
            <button class="btn btn-warning btn-group-lg   p-2 w-25 mt-1 "  type="submit">Update</button>
            <a class="btn btn-secondary  btn-group-lg   p-2 w-25 mt-1  " asp-action="Update" asp-route-id="@role">Back</a>

    </div>

    </div>



</form>


