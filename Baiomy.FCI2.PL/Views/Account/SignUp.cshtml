@model SignUpViewModel
@{
    ViewData["Title"] = "Sign Up";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<form asp-action="SignUp">
	<div asp-validation-summary="ModelOnly" ></div>
	<input class="text mg-b-3" asp-for="FirstName" placeholder="First Name" required="">
	<input class="text mg-b-3" asp-for="LastName" placeholder="Last Name" required="">
	<input class="text mg-b-3" asp-for="UserName" placeholder="User Name" required="">

	<input class="text mg-b-3" asp-for="Email" placeholder="Email" required="">
	<input class="text mg-b-3" asp-for="Password" placeholder="Password" required="">

	<input class="text w3lpass mg-b-3" asp-for="ConfirmPassword" type="password" placeholder=" Confirm Password" required="">
	<div class="wthree-text">
		<label class="anim">
			<input type="checkbox"asp-for="IsAgree" class="checkbox" required="">
			<span>I Agree To The Terms & Conditions</span>
		</label>
		<div class="clear"> </div>
	</div>
	<input type="submit" value="SIGNUP">
</form>
<p>Do you have an account ?<a asp-action="SignIn"> Login Now !</a></p>
