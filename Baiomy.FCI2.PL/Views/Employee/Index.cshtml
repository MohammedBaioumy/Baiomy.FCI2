
@model IEnumerable<EmployeesDTO>
@{
    ViewData["Title"] = "Index";
}

<div class=" row justify-content-center align-items-center ">
    <div class=" col-13 ">
        @if (TempData["Operation"] != null)
        {
            <partial name="ToastEmployeeDepartment_PartiaView"></partial>
        }


        <div>
            <a asp-controller="Employee" asp-action="Create" class="m-3 mt-4 mb-4 p-2 btn btn-outline-primary btn-lg "> Create new employee :) </a>

        </div>

        @if (Model.Count() > 0)
        {
           

            <h1 class="mb-4 me-4 p-3 ">All Employees</h1>
            <table class="table table-striped table-hover text-center rounded-2 m-2   p-3">
                <thead>
                    <tr>
                        <th>@Html.DisplayNameFor(E => E.Name)</th>
                        <th>@Html.DisplayNameFor(E => E.Email)</th>
                        <th>@Html.DisplayNameFor(E => E.Age)</th>
                        <th>@Html.DisplayNameFor(E => E.Department)</th> 
                        <th>@Html.DisplayNameFor(E => E.EmployeeType)</th>
                        <th>@Html.DisplayNameFor(E => E.Salary)</th>
                        <th>@Html.DisplayNameFor(E => E.IsActive)</th>
                        <th>@Html.DisplayNameFor(E => E.Gender)</th>
                        @* <th>@Html.DisplayNameFor(E => E.Image)</th> *@

                        <th>Details</th>
                        <th>Update</th>
                        <th>Delete</th>
                    </tr>
                </thead>
                <tbody>


                    @foreach (var employee in Model)
                    {
                        <tr>
                            <td>@Html.DisplayFor(m => employee.Name)</td>
                            <td>@Html.DisplayFor(m => employee.Email)</td>
                            <td>@Html.DisplayFor(m => employee.Age)</td>
                            <td>@Html.DisplayFor(m => employee.Department)</td>
                            <td>@Html.DisplayFor(m => employee.EmployeeType)</td>
                            <td>@Html.DisplayFor(m => employee.Salary)</td>
                            <td>@Html.DisplayFor(m => employee.IsActive)</td>
                            <td>@Html.DisplayFor(m => employee.Gender)</td>
                           @*  <td><div class="w-50 rounded-3 row justify-content-center align-content-center"><img class="img-fluid rounded-3 w-75 h-75" src="~/AttatchmentFiles/Images/@employee.Image" /></div></td> *@


                            <partial name="IndexButtons_PartialView" model="@employee.Id"></partial>


                                <!-- Modal -->
                            <td>
                                @*Delete old way*@
                                @*   <a type="button" asp-action="Delete" asp-route-id="@Model" class="btn btn-danger">
                        <i class="fa-solid fa-eye me-1"></i> Delete</a> *@


                                @*Delete using bootstrap modal *@
                                <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#DeleteModal-@employee.Id">  
                                <i class="fa-solid fa-eye me-1"></i> Delete
                                </button>
                                <div class="modal fade " id="DeleteModal-@employee.Id" tabindex="-1" aria-labelledby="DeleteModal" aria-hidden="true">
                                        <div class="modal-dialog modal-dialog-centered ">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h1 class="modal-title fs-5" id="DeleteModal">Delete Employee</h1>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <div class="modal-body">
                                                Are you sure you want to delete : @employee.Name ?
                                            </div>
                                            <div class="modal-footer">
                                                <form asp-action="Delete" asp-route-id="@employee.Id">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                                    <button type="submit" class="btn btn-danger">Delete</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                    
                            </td>

                           
                        </tr>
                    }
                </tbody>


            </table>




        }
        else
        {
            <div class="text-center alert alert-danger  mt-4 m-3 p-3 rounded-3 " role="alert">
                <h2 class=""> There is no employees :( </h2>
            </div>
        }
    </div>
</div>

